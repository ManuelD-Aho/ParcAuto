<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.miage.parcauto.controller.MissionController"
            stylesheets="../css/theme.css"
            prefWidth="1200" prefHeight="800">
    <top>
        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="dashboard-topbar">
            <Text styleClass="app-title" text="Missions" />
            <Pane HBox.hgrow="ALWAYS" />
            <Button fx:id="btnRetour" text="Retour" styleClass="btn,btn-secondary" />
        </HBox>
    </top>
    <left>
        <VBox spacing="8" styleClass="dashboard-sidebar" prefWidth="240">
            <Label styleClass="sidebar-header" text="Menu Principal" />
            <MenuButton text="Tableau de bord" />
            <MenuButton text="Véhicules" />
            <MenuButton text="Missions" />
            <MenuButton text="Finances" />
            <MenuButton text="Entretiens" />
            <MenuButton text="Documents" />
            <MenuButton text="Rapports" />
            <MenuButton text="Paramètres" />
        </VBox>
    </left>
    <center>
        <VBox spacing="24" padding="24" styleClass="mission-center">
            <HBox spacing="16">
                <TextField fx:id="txtReference" promptText="Référence" />
                <ComboBox fx:id="comboVehicule" promptText="Véhicule" />
                <ComboBox fx:id="comboConducteur" promptText="Conducteur" />
                <DatePicker fx:id="dateDebut" promptText="Début" />
                <DatePicker fx:id="dateFin" promptText="Fin" />
                <TextField fx:id="txtDestination" promptText="Destination" />
                <ComboBox fx:id="comboStatut" promptText="Statut" />
            </HBox>
            <HBox spacing="8">
                <Button fx:id="btnAjouter" text="Ajouter" styleClass="btn,btn-success" />
                <Button fx:id="btnModifier" text="Modifier" styleClass="btn,btn-primary" />
                <Button fx:id="btnSupprimer" text="Supprimer" styleClass="btn,btn-danger" />
                <Button fx:id="btnCloturer" text="Clôturer" styleClass="btn,btn-warning" />
            </HBox>
            <TitledPane text="Liste des missions">
                <TableView fx:id="tableMissions">
                    <columns>
                        <TableColumn fx:id="colReference" text="Référence" />
                        <TableColumn fx:id="colVehicule" text="Véhicule" />
                        <TableColumn fx:id="colConducteur" text="Conducteur" />
                        <TableColumn fx:id="colDateDebut" text="Début" />
                        <TableColumn fx:id="colDateFin" text="Fin" />
                        <TableColumn fx:id="colDestination" text="Destination" />
                        <TableColumn fx:id="colStatut" text="Statut" />
                    </columns>
                </TableView>
            </TitledPane>
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="dashboard-statusbar" />
    </bottom>
</BorderPane>
