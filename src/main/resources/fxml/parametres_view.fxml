<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.miage.parcauto.controller.ParametresController"
            stylesheets="../css/theme.css"
            prefWidth="1200" prefHeight="800">
    <top>
        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="dashboard-topbar">
            <Text styleClass="app-title" text="Paramètres" />
            <Pane HBox.hgrow="ALWAYS" />
            <Button fx:id="btnRetour" text="Retour" styleClass="btn,btn-secondary" />
        </HBox>
    </top>
    <left>
        <VBox spacing="8" styleClass="dashboard-sidebar" prefWidth="240">
            <Label styleClass="sidebar-header" text="Menu Principal" />
            <MenuButton text="Tableau de bord" />
            <MenuButton text="Véhicules" />
            <MenuButton text="Missions" />
            <MenuButton text="Finances" />
            <MenuButton text="Entretiens" />
            <MenuButton text="Documents" />
            <MenuButton text="Rapports" />
            <MenuButton text="Paramètres" />
        </VBox>
    </left>
    <center>
        <VBox spacing="24" padding="24" styleClass="parametres-center">
            <TitledPane text="Gestion des utilisateurs">
                <TableView fx:id="tableUtilisateurs">
                    <columns>
                        <TableColumn fx:id="colNom" text="Nom" />
                        <TableColumn fx:id="colPrenom" text="Prénom" />
                        <TableColumn fx:id="colLogin" text="Login" />
                        <TableColumn fx:id="colRole" text="Rôle" />
                        <TableColumn fx:id="colActions" text="Actions" />
                    </columns>
                </TableView>
            </TitledPane>
            <HBox spacing="16">
                <Button fx:id="btnAjouterUtilisateur" text="Ajouter utilisateur" styleClass="btn,btn-success" />
                <Button fx:id="btnModifierUtilisateur" text="Modifier" styleClass="btn,btn-primary" />
                <Button fx:id="btnSupprimerUtilisateur" text="Supprimer" styleClass="btn,btn-danger" />
                <Button fx:id="btnExporterLogs" text="Exporter logs" styleClass="btn,btn-secondary" />
            </HBox>
            <TitledPane text="Sauvegarde et restauration">
                <HBox spacing="16">
                    <Button fx:id="btnSauvegarder" text="Sauvegarder la base" styleClass="btn,btn-primary" />
                    <Button fx:id="btnRestaurer" text="Restaurer" styleClass="btn,btn-warning" />
                </HBox>
            </TitledPane>
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="dashboard-statusbar" />
    </bottom>
</BorderPane>
