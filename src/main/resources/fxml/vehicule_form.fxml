<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.miage.parcauto.controller.VehiculeController"
            stylesheets="../css/theme.css"
            prefWidth="1200" prefHeight="800">
    <top>
        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="dashboard-topbar">
            <Text styleClass="app-title" text="Véhicules" />
            <Pane HBox.hgrow="ALWAYS" />
            <Button fx:id="btnRetour" text="Retour" styleClass="btn,btn-secondary" />
        </HBox>
    </top>
    <left>
        <VBox spacing="8" styleClass="dashboard-sidebar" prefWidth="240">
            <Label styleClass="sidebar-header" text="Menu Principal" />
            <MenuButton text="Tableau de bord" />
            <MenuButton text="Véhicules" />
            <MenuButton text="Missions" />
            <MenuButton text="Finances" />
            <MenuButton text="Entretiens" />
            <MenuButton text="Documents" />
            <MenuButton text="Rapports" />
            <MenuButton text="Paramètres" />
        </VBox>
    </left>
    <center>
        <VBox spacing="24" padding="24" styleClass="vehicule-center">
            <HBox spacing="16">
                <TextField fx:id="txtImmatriculation" promptText="Immatriculation" />
                <TextField fx:id="txtMarque" promptText="Marque" />
                <TextField fx:id="txtModele" promptText="Modèle" />
                <TextField fx:id="txtCouleur" promptText="Couleur" />
                <TextField fx:id="txtKilometrage" promptText="Kilométrage" />
                <ComboBox fx:id="comboStatut" promptText="Statut" />
            </HBox>
            <HBox spacing="8">
                <Button fx:id="btnAjouter" text="Ajouter" styleClass="btn,btn-success" />
                <Button fx:id="btnModifier" text="Modifier" styleClass="btn,btn-primary" />
                <Button fx:id="btnSupprimer" text="Supprimer" styleClass="btn,btn-danger" />
                <Button fx:id="btnDeclarerPanne" text="Déclarer panne" styleClass="btn,btn-warning" />
            </HBox>
            <TitledPane text="Liste des véhicules">
                <TableView fx:id="tableVehicules">
                    <columns>
                        <TableColumn fx:id="colImmatriculation" text="Immatriculation" />
                        <TableColumn fx:id="colMarque" text="Marque" />
                        <TableColumn fx:id="colModele" text="Modèle" />
                        <TableColumn fx:id="colCouleur" text="Couleur" />
                        <TableColumn fx:id="colKilometrage" text="Kilométrage" />
                        <TableColumn fx:id="colStatut" text="Statut" />
                    </columns>
                </TableView>
            </TitledPane>
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="dashboard-statusbar" />
    </bottom>
</BorderPane>
