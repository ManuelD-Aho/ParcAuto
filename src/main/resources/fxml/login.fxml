<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.miage.parcauto.controller.LoginController"
            stylesheets="../css/theme.css"
            prefWidth="1000" prefHeight="600">
    <center>
        <StackPane alignment="CENTER">
            <HBox alignment="CENTER" spacing="30" styleClass="login-container">
                <!-- Logo et informations de l'application -->
                <VBox alignment="CENTER" styleClass="login-banner" prefWidth="500" prefHeight="400" spacing="20">
                    <ImageView fitHeight="150" fitWidth="150" preserveRatio="true">
                        <Image url="@../images/logo.png" />
                    </ImageView>
                    <Text text="ParcAuto" styleClass="app-name">
                        <font>
                            <Font name="System Bold" size="36" />
                        </font>
                    </Text>
                    <Text text="Gestion de Parc Automobile" styleClass="app-tagline">
                        <font>
                            <Font size="18" />
                        </font>
                    </Text>
                    <Text text="v1.0" styleClass="app-version" />
                </VBox>

                <!-- Formulaire de connexion -->
                <VBox alignment="CENTER" styleClass="login-form-container" prefWidth="400" prefHeight="400" spacing="20">
                    <padding>
                        <Insets top="30" right="40" bottom="30" left="40" />
                    </padding>
                    <Text text="Connexion" styleClass="login-title">
                        <font>
                            <Font size="24" />
                        </font>
                    </Text>
                    <TextField fx:id="txtUsername" promptText="Nom d'utilisateur" styleClass="login-field">
                        <VBox.margin>
                            <Insets top="20" />
                        </VBox.margin>
                    </TextField>
                    <PasswordField fx:id="txtPassword" promptText="Mot de passe" styleClass="login-field" />
                    <HBox alignment="CENTER_RIGHT">
                        <Hyperlink fx:id="lnkForgotPassword" text="Mot de passe oublié ?" styleClass="forgot-password" />
                    </HBox>
                    <Button fx:id="btnConnexion" text="Se connecter" styleClass="btn,btn-primary,login-button" 
                            onAction="#handleConnexion" defaultButton="true" />
                    <Label fx:id="lblError" styleClass="login-error" text="" />
                </VBox>
            </HBox>
        </StackPane>
    </center>
    <bottom>
        <HBox alignment="CENTER" styleClass="login-footer">
            <padding>
                <Insets top="10" right="0" bottom="10" left="0" />
            </padding>
            <Label text="© 2025 MIAGE Holding - Tous droits réservés" />
        </HBox>
    </bottom>
</BorderPane>
